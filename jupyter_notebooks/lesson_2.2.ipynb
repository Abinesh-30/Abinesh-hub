   "source": [
    "\n",
    "word = \"charactically\"\n",
    "\n",
    "letter = input(\"Enter a single letter: \")\n",
    "found = False\n",
    "\n",
    "for char in word: \n",
    "    if char == letter:\n",
    "        found = True\n",
    "        break\n",
    "\n",
    "if found:\n",
    "    print(\"letter found\")\n",
    "else:\n",
    "    print(\"letter not found\")"
   ]
  }
